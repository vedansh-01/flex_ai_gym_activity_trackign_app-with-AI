					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 401', () => pm.response.to.have.status(401));"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "POST /api/ai/meal-plan – No Token (401)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"prompt\": \"Give me a high protein meal\"}"
						},
						"url": {
							"raw": "{{base_url}}/api/ai/meal-plan",
