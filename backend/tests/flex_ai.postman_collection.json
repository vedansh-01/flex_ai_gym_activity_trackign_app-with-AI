								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "POST /api/ai/workout – Invalid Token (401)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer invalid-fake-token-xyz" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"prompt\": \"Give me a chest workout\"}"
