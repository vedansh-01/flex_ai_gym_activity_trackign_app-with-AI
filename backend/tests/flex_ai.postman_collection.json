								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "3. Subscription Management",
			"item": [
				{
					"name": "GET /api/ai/subscription/status – Check Status",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/ai/subscription/status",
							"host": ["{{base_url}}"],
							"path": ["api", "ai", "subscription", "status"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has active field', () => { const body = pm.response.json(); pm.expect(body).to.have.property('active'); });"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "POST /api/ai/subscription/activate – Activate Code",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"code\": \"Mirrorofgym1month@123\"}"
						},
						"url": {
							"raw": "{{base_url}}/api/ai/subscription/activate",
							"host": ["{{base_url}}"],
							"path": ["api", "ai", "subscription", "activate"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Returns expiry', () => { const body = pm.response.json(); pm.expect(body).to.have.property('expires_at'); });"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "POST /api/ai/subscription/activate – Empty Code (400)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{base_url}}/api/ai/subscription/activate",
							"host": ["{{base_url}}"],
							"path": ["api", "ai", "subscription", "activate"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 400', () => pm.response.to.have.status(400));",
									"pm.test('Has error message', () => { const body = pm.response.json(); pm.expect(body.message).to.match(/required/i); });"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "4. AI Chat",
			"item": [
				{
					"name": "POST /api/chat/send – Send Message",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"text\": \"What exercises should I do today for shoulders?\"}"
						},
						"url": {
							"raw": "{{base_url}}/api/chat/send",
							"host": ["{{base_url}}"],
							"path": ["api", "chat", "send"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has AI content', () => { const body = pm.response.json(); pm.expect(body).to.have.property('content'); pm.expect(body.role).to.equal('assistant'); });"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "5. AI Workout Generator",
			"item": [
				{
					"name": "POST /api/ai/workout – Generate Workout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"prompt\": \"Generate a full chest workout for a beginner\"}"
						},
						"url": {
							"raw": "{{base_url}}/api/ai/workout",
							"host": ["{{base_url}}"],
							"path": ["api", "ai", "workout"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has workout_name', () => { const body = pm.response.json(); pm.expect(body).to.have.property('workout_name'); });",
									"pm.test('Has exercises array', () => { const body = pm.response.json(); pm.expect(body.exercises).to.be.an('array'); });"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "POST /api/ai/workout – Missing Prompt (400)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{base_url}}/api/ai/workout",
							"host": ["{{base_url}}"],
							"path": ["api", "ai", "workout"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 400', () => pm.response.to.have.status(400));",
									"pm.test('Has error message', () => { const body = pm.response.json(); pm.expect(body.message).to.match(/prompt.*required/i); });"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "6. AI Meal Planner",
			"item": [
				{
					"name": "POST /api/ai/meal-plan – Generate Meal Plan",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\"prompt\": \"Give me a high protein post-workout meal under 500 calories\"}"
						},
						"url": {
							"raw": "{{base_url}}/api/ai/meal-plan",
							"host": ["{{base_url}}"],
							"path": ["api", "ai", "meal-plan"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has meal_name', () => { const body = pm.response.json(); pm.expect(body).to.have.property('meal_name'); });",
									"pm.test('Has foods array', () => { const body = pm.response.json(); pm.expect(body.foods).to.be.an('array'); });"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		}
	]
